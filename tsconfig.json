{
	// One project spans both browser (client, `lib: DOM`) and server (worker, node)
	// code, so `types` mixes Workers + Node globals with DOM lib types. The
	// resulting name collisions (e.g. `fetch`, `Request`) are masked by
	// skipLibCheck below rather than resolved via separate per-target configs.
	// A full split is a larger effort tracked in issue #56; left as a single
	// project for now.
	"compilerOptions": {
		"outDir": "./.tsbuild",
		"types": ["@cloudflare/workers-types", "node"],
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"importHelpers": true,
		"resolveJsonModule": true,
		"incremental": true,
		"jsx": "react-jsx",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"module": "esnext",
		"target": "esnext",
		"moduleResolution": "node",
		"noFallthroughCasesInSwitch": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"skipLibCheck": true,
		"strict": true,
		"strictFunctionTypes": true,
		"strictNullChecks": true,
		"useDefineForClassFields": true,
		"noImplicitOverride": true
	},
	"exclude": ["node_modules"],
	"include": ["client", "shared", "worker", "server"],
	"files": ["./vite.config.ts"]
}
